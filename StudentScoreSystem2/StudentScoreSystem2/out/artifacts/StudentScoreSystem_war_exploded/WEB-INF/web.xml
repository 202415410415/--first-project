<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         version="4.0">
    <!-- 欢迎页：访问根路径直接到Servlet，跳首页 -->
    <welcome-file-list>
        <welcome-file>score</welcome-file>
    </welcome-file-list>

    <!-- 核心Servlet：映射路径/score -->
    <servlet>
        <servlet-name>ScoreServlet</servlet-name>
        <servlet-class>com.score.controller.StudentScoreSystem</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ScoreServlet</servlet-name>
        <url-pattern>/score</url-pattern>
    </servlet-mapping>
</web-app>